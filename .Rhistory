# Load necessary libraries
library(rpart)
library(rpart.plot)
data_fin_exam<-train_data
# Build the decision tree with default parameters
tree_model <- rpart(Y ~ ., data = data_fin_exam)
# Plot the decision tree with class probabilities and number of observations per node
rpart.plot(tree_model, type = 2, extra = 104)
# Large/deep tree
large_tree <- rpart(target_var ~ ., data = data_fin_exam,
control = rpart.control(cp = 0.001, minsplit = 2, maxdepth = 30))
# Large/deep tree
large_tree <- rpart(Y ~ ., data = data_fin_exam,
control = rpart.control(cp = 0.001, minsplit = 2, maxdepth = 30))
# Small/shallow tree
small_tree <- rpart(Y ~ ., data = data_fin_exam,
control = rpart.control(cp = 0.05, minsplit = 20, maxdepth = 5))
# Plot both trees
rpart.plot(large_tree, type = 4, extra = 104, main = "Large/Deep Tree")
rpart.plot(small_tree, type = 4, extra = 104, main = "Small/Shallow Tree")
# Comparing ROC/AUC on holdout set (assume 'test_data' is your holdout set)
# You can install and load the pROC package if needed
library(pROC)
# Large tree prediction
pred_large <- predict(large_tree, newdata = test_data, type = "prob")[,2]
roc_large <- roc(test_data$Y, pred_large)
auc(roc_large)
# Small tree prediction
pred_small <- predict(small_tree, newdata = test_data, type = "prob")[,2]
roc_small <- roc(test_data$Y, pred_small)
auc(roc_small)
# Print complexity parameter (cp) table for large tree
printcp(large_tree)
# Description of printcp output:
# - The 'CP' column shows the complexity parameter, which controls the tree pruning.
# - 'nsplit' gives the number of splits or nodes in the tree.
# - 'rel error' is the relative error of the model, starting at 1.0 for no splits.
# - 'xerror' is the cross-validated error, and 'xstd' is its standard deviation.
# The goal is to find the CP that minimizes cross-validated error (xerror).
# Arbitrary pruning to a number of leaves (say, 5 leaves)
pruned_tree <- prune(large_tree, cp = 0.02) # Adjust cp to reduce to the desired number of leaves
# Plot pruned tree
rpart.plot(pruned_tree, type = 4, extra = 104, main = "Pruned Tree")
# Plot the cross-validation results to find optimal cp
plotcp(large_tree)
# Prune the tree using the optimal cp value
optimal_cp <- large_tree$cptable[which.min(large_tree$cptable[,"xerror"]), "CP"]
optimal_tree <- prune(large_tree, cp = optimal_cp)
# Plot the optimal tree
rpart.plot(optimal_tree, main = "Optimal Tree", extra = 106)
# Compare the optimal model AUC with large and small trees
pred_optimal <- predict(optimal_tree, newdata = test_set, type = "prob")[,2]
# Plot the cross-validation results to find optimal cp
plotcp(large_tree)
# Prune the tree using the optimal cp value
optimal_cp <- large_tree$cptable[which.min(large_tree$cptable[,"xerror"]), "CP"]
optimal_tree <- prune(large_tree, cp = optimal_cp)
# Plot the optimal tree
rpart.plot(optimal_tree, main = "Optimal Tree", extra = 106)
# Compare the optimal model AUC with large and small trees
pred_optimal <- predict(optimal_tree, newdata = test_data, type = "prob")[,2]
pred_optimal_roc <- prediction(pred_optimal, test_data$Y)
library(ROCR)
# Plot the cross-validation results to find optimal cp
plotcp(large_tree)
# Prune the tree using the optimal cp value
optimal_cp <- large_tree$cptable[which.min(large_tree$cptable[,"xerror"]), "CP"]
optimal_tree <- prune(large_tree, cp = optimal_cp)
# Plot the optimal tree
rpart.plot(optimal_tree, main = "Optimal Tree", extra = 106)
# Compare the optimal model AUC with large and small trees
pred_optimal <- predict(optimal_tree, newdata = test_data, type = "prob")[,2]
pred_optimal_roc <- prediction(pred_optimal, test_data$Y)
