library(gbm)
# Train a gradient boosting model using logistic loss
gbm_model <- gbm(Y ~ .,
data = data_fin_exam,
distribution = "bernoulli",
n.trees = 500,
interaction.depth = 1,
shrinkage = 0.01,
n.minobsinnode = 10,
bag.fraction = 0.5)
# Compare with exponential loss (AdaBoost)
gbm_adaboost <- gbm(Y ~ .,
data = data_fin_exam,
distribution = "adaboost",
n.trees = 500,
interaction.depth = 1,
shrinkage = 0.01,
n.minobsinnode = 10,
bag.fraction = 0.5)
# Predict on the test set and compare AUC
pred_gbm <- predict(gbm_model, newdata = test_data, n.trees = 500, type = "response")
pred_adaboost <- predict(gbm_adaboost, newdata = test_data, n.trees = 500, type = "response")
pred_gbm_roc <- prediction(pred_gbm, test_data$Y)
