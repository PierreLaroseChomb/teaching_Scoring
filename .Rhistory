# Set the number of folds
K <- 5
folds <- createFolds(y_train, k = K)
# Initialize a matrix to store AUC for each fold and lambda
cv_auc <- matrix(NA, nrow = K, ncol = length(lasso_model$lambda)+40)
# Outer loop for each fold
for (k in seq_len(K)) {
# Split data into training and validation for this fold
train_fold <- train_data[-folds[[k]], ]
valid_fold <- train_data[folds[[k]], ]
# Prepare the training and validation sets
x_train_fold <- as.matrix(train_fold[, -which(names(train_fold) == "Y")])
y_train_fold <- as.matrix(train_fold$Y)
x_valid_fold <- as.matrix(valid_fold[, -which(names(valid_fold) == "Y")])
y_valid_fold <- as.matrix(valid_fold$Y)
# Fit Lasso model on this fold's training data
lasso_model_fold <- glmnet(x_train_fold, y_train_fold, alpha = 1)
# Predict on validation data for all lambdas
pred_probs_fold <- predict(lasso_model_fold, newx = x_valid_fold, type = "response")
# Compute AUC for each lambda
for (i in seq_along(lasso_model_fold$lambda)) {
pred <- pred_probs_fold[, i]
cv_auc[k, i] <- auc(roc(y_valid_fold, pred))
}
}
# Compute the mean AUC across all folds for each lambda
mean_cv_auc <- colMeans(cv_auc, na.rm = TRUE)
# Best lambda based on cross-validation AUC
best_lambda_cv <- lasso_model$lambda[which.max(mean_cv_auc)]
best_lambda_cv
# Use the built-in cv.glmnet for comparison
cv_model <- cv.glmnet(x_train, y_train, alpha = 1)
# Compare lambdas
cat("Best lambda from manual CV:", best_lambda_cv, "\n")
cat("Best lambda from cv.glmnet:", cv_model$lambda.min, "\n")
